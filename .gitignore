# ============================================
*.cf
*.dt
*.epf
*.erf
*.cfl
*.log
*.lgp
*.cfs
*.cfu
1Cv8.1CD
1Cv8_log
*.mxl

# ============================================
# Python (если будут скрипты для тестов)
# ============================================
pycache/
*.py[cod]
*$py.class
venv/
env/
.venv/
.env
*.egg-info/
dist/
build/

# ============================================
# Node.js / JavaScript (для мок-сервера)
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ============================================
# Временные и резервные копии
# ============================================
*.tmp
*.temp
*.bak
*.backup
*.old
*.orig

# ============================================
# Логи и отчеты
# ============================================
*.log
*.report
test-results/

# ============================================
# Архивы (не храним в репе)
# ============================================
*.zip
*.rar
*.7z
*.tar.gz

# ============================================
# Секреты и конфиги с паролями
# ============================================
*.key
*.pem
secrets.json
config.local.*