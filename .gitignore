# ============================================
# Системные файлы (ОС)
# ============================================
.DS_Store
Thumbs.db
desktop.ini
._*

# ============================================
# IDE и редакторы
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

